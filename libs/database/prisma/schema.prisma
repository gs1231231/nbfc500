model SystemConfig {
  id             String   @id @default(uuid())
  organizationId String   @unique
  logo           String?
  letterhead     String?
  gstin          String?
  pan            String?
  cin            String?
  registeredAddress String?
  signatoryName  String?
  signatoryDesignation String?
  smsSenderId    String?
  fiscalYearStart Int     @default(4) // April
  defaultInterestCalcMethod String @default("REDUCING_MONTHLY")
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  @@map("system_configs")
}

model ProductFeeConfig {
  id             String   @id @default(uuid())
  organizationId String
  productId      String
  feeType        String   // PROCESSING, LOGIN, LEGAL, VALUATION, STAMP_DUTY, INSURANCE, BOUNCE, PENAL, PREPAYMENT, FORECLOSURE
