{
  "name": "bankos",
  "version": "0.1.0",
  "private": true,
  "description": "BankOS - NBFC Lending Platform",
  "scripts": {
    "build": "nest build",
    "build:api-gateway": "nest build api-gateway",
    "build:los-service": "nest build los-service",
    "build:lms-service": "nest build lms-service",
    "build:bre-service": "nest build bre-service",
    "build:collection-service": "nest build collection-service",
    "build:bureau-service": "nest build bureau-service",
    "build:payment-service": "nest build payment-service",
    "build:notification-service": "nest build notification-service",
    "build:colending-service": "nest build colending-service",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "start:api-gateway": "nest start api-gateway --watch",
    "start:los-service": "nest start los-service --watch",
    "start:lms-service": "nest start lms-service --watch",
    "start:bre-service": "nest build bre-service --watch",
    "start:collection-service": "nest start collection-service --watch",
    "start:bureau-service": "nest start bureau-service --watch",
    "start:payment-service": "nest start payment-service --watch",
    "start:notification-service": "nest start notification-service --watch",
    "start:colending-service": "nest start colending-service --watch",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "format": "prettier --write \"{apps,libs}/**/*.ts\"",
    "format:check": "prettier --check \"{apps,libs}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./jest-e2e.json",
    "prisma:generate": "prisma generate --schema=libs/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=libs/database/prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema=libs/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=libs/database/prisma/schema.prisma",
    "prisma:seed": "ts-node libs/database/prisma/seed.ts",
    "prisma:seed-org2": "ts-node libs/database/prisma/seed-org2.ts",
    "prepare": "husky install",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.0",
    "@prisma/client": "^5.18.0",
    "@sentry/node": "^10.45.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.4.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.3.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prisma": "^5.18.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "@bankos/common/(.*)": "<rootDir>/libs/common/src/$1",
      "@bankos/common": "<rootDir>/libs/common/src",
      "@bankos/database/(.*)": "<rootDir>/libs/database/src/$1",
      "@bankos/database": "<rootDir>/libs/database/src",
      "@bankos/auth/(.*)": "<rootDir>/libs/auth/src/$1",
      "@bankos/auth": "<rootDir>/libs/auth/src",
      "@bankos/events/(.*)": "<rootDir>/libs/events/src/$1",
      "@bankos/events": "<rootDir>/libs/events/src",
      "@bankos/custom-fields/(.*)": "<rootDir>/libs/custom-fields/src/$1",
      "@bankos/custom-fields": "<rootDir>/libs/custom-fields/src",
      "@bankos/workflow/(.*)": "<rootDir>/libs/workflow/src/$1",
      "@bankos/workflow": "<rootDir>/libs/workflow/src"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "prisma": {
    "seed": "ts-node libs/database/prisma/seed.ts"
  }
}
