# ─────────────────────────────────────────────
# BankOS Environment Variables — Example File
# Copy to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL via Prisma) ─────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://bankos_user:bankos_pass@localhost:5432/bankos_db?schema=public

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRY=900s
JWT_REFRESH_SECRET=change-me-to-a-different-long-secret
JWT_REFRESH_EXPIRY=7d

# ── API Gateway ───────────────────────────────
API_GATEWAY_PORT=3000
API_GATEWAY_PREFIX=api/v1

# ── Auth Service ──────────────────────────────
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=localhost

# ── Loan Service ──────────────────────────────
LOAN_SERVICE_PORT=3002
LOAN_SERVICE_HOST=localhost

# ── Payment Service ───────────────────────────
PAYMENT_SERVICE_PORT=3003
PAYMENT_SERVICE_HOST=localhost

# ── KYC Service ───────────────────────────────
KYC_SERVICE_PORT=3004
KYC_SERVICE_HOST=localhost

# ── Notification Service ──────────────────────
NOTIFICATION_SERVICE_PORT=3005
NOTIFICATION_SERVICE_HOST=localhost

# ── SMTP / Email ─────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bankos.io

# ── SMS / OTP Provider ────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Storage (S3-compatible) ───────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=ap-south-1
S3_BUCKET=bankos-documents
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Razorpay / Payment Gateway ────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Encryption ───────────────────────────────
ENCRYPTION_KEY=32-byte-hex-encoded-key-here
ENCRYPTION_IV_LENGTH=16

# ── Rate Limiting ─────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Logging ───────────────────────────────────
LOG_LEVEL=debug
